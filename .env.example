# General Configuration
NODE_ENV=development
PORT=5000

# MTN API Base URL
MTN_API_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Environment
MTN_ENVIRONMENT=sandbox

# Callback Configuration
MTN_CALLBACK_HOST=https://your-webhook-url.com

# Subscription Keys
MTN_COLLECTION_PRIMARY_KEY=your_collection_primary_key
MTN_DISBURSEMENT_PRIMARY_KEY=your_disbursement_primary_key
MTN_REMITTANCE_PRIMARY_KEY=your_remittance_primary_key

# API User IDs
MTN_COLLECTION_USER_ID=your_collection_user_id
MTN_DISBURSEMENT_USER_ID=your_disbursement_user_id
MTN_REMITTANCE_USER_ID=your_remittance_user_id

# API Secrets
MTN_COLLECTION_API_SECRET=your_collection_api_secret
MTN_DISBURSEMENT_API_SECRET=your_disbursement_api_secret
MTN_REMITTANCE_API_SECRET=your_remittance_api_secret

# Authentication URLs
MTN_AUTH_COLLECTIONS_URL=https://sandbox.momodeveloper.mtn.com/collection/token/
MTN_AUTH_DISBURSEMENTS_URL=https://sandbox.momodeveloper.mtn.com/disbursement/token/
MTN_AUTH_REMITTANCES_URL=https://sandbox.momodeveloper.mtn.com/remittance/token/

# Transaction Endpoints
MTN_COLLECTIONS_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0
MTN_DISBURSEMENTS_URL=https://sandbox.momodeveloper.mtn.com/disbursement/v1_0
MTN_REMITTANCES_URL=https://sandbox.momodeveloper.mtn.com/remittance/v1_0/